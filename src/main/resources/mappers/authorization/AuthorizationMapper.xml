<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minicard.authorization.infrastructure.mybatis.AuthorizationMapper">

    <resultMap id="authorizationRowMap"
               type="com.minicard.authorization.infrastructure.mybatis.AuthorizationRow">
        <!--
          constructor mapping 直接创建 immutable record。若改成 setter-based POJO，
          row DTO 会变成可变对象，mapping 后还可能被意外修改。
        -->
        <constructor>
            <arg column="id" javaType="java.lang.String"/>
            <arg column="idempotency_key" javaType="java.lang.String"/>
            <arg column="request_fingerprint" javaType="java.lang.String"/>
            <arg column="card_id" javaType="java.lang.String"/>
            <arg column="amount" javaType="java.math.BigDecimal"/>
            <arg column="currency" javaType="java.lang.String"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="decline_reason" javaType="java.lang.String"/>
            <arg column="created_at" javaType="java.time.Instant"/>
            <arg column="decided_at" javaType="java.time.Instant"/>
            <arg column="expires_at" javaType="java.time.Instant"/>
            <arg column="posted_at" javaType="java.time.Instant"/>
            <arg column="expired_at" javaType="java.time.Instant"/>
        </constructor>
    </resultMap>

    <sql id="authorizationColumns">
        id, idempotency_key, request_fingerprint, card_id, amount, currency, status,
        decline_reason, created_at, decided_at, expires_at, posted_at, expired_at
    </sql>

    <select id="findById" resultMap="authorizationRowMap">
        <!--
          查询样例：id='66666666-6666-6666-6666-666666666660'。
          访问路径：走 PRIMARY KEY(id)，用于 GET /api/authorizations/{id} 这类精确查询。
        -->
        SELECT <include refid="authorizationColumns"/>
        FROM authorizations
        <!--
          #{id} 是 bind parameter，会走 PreparedStatement。
          如果为了拼 SQL 改用 ${id}，用户输入会直接进入 SQL 字符串，产生 SQL injection 风险。
        -->
        WHERE id = #{id}
    </select>

    <!--
      INSERT-first idempotency：先写入 claim，避免 read-then-insert race。
      unique idempotency_key constraint 会在并发请求中选出唯一 winner。
      防重复样例：两次 INSERT 都带 idempotency_key='auth-seed-approved-hold'，
      只有第一条能成功，第二条由 repository 捕获 DuplicateKeyException 后转为“读取原结果”。
    -->
    <insert id="insert">
        INSERT INTO authorizations (
            id, idempotency_key, request_fingerprint, card_id, amount, currency,
            status, decline_reason, created_at, decided_at, expires_at, posted_at, expired_at
        ) VALUES (
            #{authorization.id},
            #{authorization.idempotencyKey},
            #{authorization.requestFingerprint},
            #{authorization.cardId},
            #{authorization.amount},
            #{authorization.currency},
            #{authorization.status},
            #{authorization.declineReason,jdbcType=VARCHAR},
            #{authorization.createdAt},
            #{authorization.decidedAt,jdbcType=TIMESTAMP},
            #{authorization.expiresAt,jdbcType=TIMESTAMP},
            #{authorization.postedAt,jdbcType=TIMESTAMP},
            #{authorization.expiredAt,jdbcType=TIMESTAMP}
        )
    </insert>

    <!--
      concurrent duplicate 会等待 winner transaction，然后读取最终状态。
      这样 duplicate 不会再次执行 credit reservation。
      查询样例：idempotency_key='auth-seed-approved-hold'。
      对应索引：uk_authorizations_idempotency_key(idempotency_key)。
      锁语义：FOR UPDATE 锁住 winner row，让并发 duplicate 等到 APPROVED/DECLINED 最终状态后再返回。
    -->
    <select id="findByIdempotencyKeyForUpdate" resultMap="authorizationRowMap">
        SELECT <include refid="authorizationColumns"/>
        FROM authorizations
        WHERE idempotency_key = #{idempotencyKey}
        FOR UPDATE
    </select>

    <!--
      DelayJobWorker 处理的是已经 claim 的 delay job；这里仍要锁 authorization row。
      原因是 business state 才是释放 reserved credit 前的 source of truth。
      查询样例：id='66666666-6666-6666-6666-666666666664'。
      锁语义：FOR UPDATE 防止 expiry release 与 presentment posting 同时改同一 authorization 状态。
    -->
    <select id="findByIdForUpdate" resultMap="authorizationRowMap">
        SELECT <include refid="authorizationColumns"/>
        FROM authorizations
        WHERE id = #{id}
        FOR UPDATE
    </select>

    <update id="update">
        <!--
          更新样例：APPROVED 会写 decided_at/expires_at；DECLINED 会写 decline_reason；
          POSTED 会写 posted_at；EXPIRED 会写 expired_at。
          DB CHECK chk_authorizations_decision_state 会兜底阻止“状态和时间字段不自洽”的 row。
        -->
        UPDATE authorizations
        SET status = #{status},
            decline_reason = #{declineReason,jdbcType=VARCHAR},
            decided_at = #{decidedAt,jdbcType=TIMESTAMP},
            expires_at = #{expiresAt,jdbcType=TIMESTAMP},
            posted_at = #{postedAt,jdbcType=TIMESTAMP},
            expired_at = #{expiredAt,jdbcType=TIMESTAMP}
        WHERE id = #{id}
    </update>

</mapper>
