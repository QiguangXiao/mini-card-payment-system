<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minicard.scheduling.infrastructure.mybatis.DelayJobMapper">

    <resultMap id="delayJobRowMap"
               type="com.minicard.scheduling.infrastructure.mybatis.DelayJobRow">
        <constructor>
            <arg column="id" javaType="java.lang.String"/>
            <arg column="job_type" javaType="java.lang.String"/>
            <arg column="aggregate_type" javaType="java.lang.String"/>
            <arg column="aggregate_id" javaType="java.lang.String"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="attempts" javaType="int"/>
            <arg column="scheduled_at" javaType="java.time.Instant"/>
            <arg column="next_attempt_at" javaType="java.time.Instant"/>
            <arg column="created_at" javaType="java.time.Instant"/>
            <arg column="updated_at" javaType="java.time.Instant"/>
            <arg column="last_error" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <sql id="delayJobColumns">
        id, job_type, aggregate_type, aggregate_id, status, attempts,
        scheduled_at, next_attempt_at, created_at, updated_at, last_error
    </sql>

    <insert id="insert">
        INSERT INTO delay_jobs (
            <include refid="delayJobColumns"/>
        ) VALUES (
            #{id},
            #{jobType},
            #{aggregateType},
            #{aggregateId},
            #{status},
            #{attempts},
            #{scheduledAt},
            #{nextAttemptAt},
            #{createdAt},
            #{updatedAt},
            #{lastError,jdbcType=VARCHAR}
        )
    </insert>

    <!--
      这和 Outbox claim query 对称：按稳定顺序选择 due rows，并使用 SKIP LOCKED。
      多个 pod 可以安全并发扫描；PROCESSING row 只有 lease 到期后才会再次 runnable。
    -->
    <select id="findNextRunnableForUpdate" resultMap="delayJobRowMap">
        SELECT <include refid="delayJobColumns"/>
        FROM delay_jobs
        WHERE status IN ('PENDING', 'PROCESSING')
          AND next_attempt_at &lt;= #{now}
        ORDER BY next_attempt_at, created_at, id
        LIMIT 1
        FOR UPDATE SKIP LOCKED
    </select>

    <select id="findByIdForUpdate" resultMap="delayJobRowMap">
        SELECT <include refid="delayJobColumns"/>
        FROM delay_jobs
        WHERE id = #{id}
        FOR UPDATE
    </select>

    <update id="updateExecutionState">
        UPDATE delay_jobs
        SET status = #{status},
            attempts = #{attempts},
            next_attempt_at = #{nextAttemptAt},
            updated_at = #{updatedAt},
            last_error = #{lastError,jdbcType=VARCHAR}
        WHERE id = #{id}
    </update>

</mapper>
