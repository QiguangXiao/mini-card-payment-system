<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minicard.creditaccount.infrastructure.mybatis.CreditAccountMapper">

    <resultMap id="creditAccountRowMap"
               type="com.minicard.creditaccount.infrastructure.mybatis.CreditAccountRow">
        <constructor>
            <arg column="id" javaType="java.lang.String"/>
            <arg column="credit_limit" javaType="java.math.BigDecimal"/>
            <arg column="reserved_amount" javaType="java.math.BigDecimal"/>
            <arg column="posted_balance" javaType="java.math.BigDecimal"/>
            <arg column="currency" javaType="java.lang.String"/>
            <arg column="status" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <!--
      FOR UPDATE 的锁会一直持有到 service transaction commit。
      授权、入账、还款都通过这条 locking read 串行修改同一个账户余额。
      查询样例：accountId='11111111-1111-1111-1111-111111111111'。
      访问路径：走 credit_accounts.PRIMARY KEY(id)，只锁这一张额度账户 row。
      如果改成普通 SELECT，两笔并发授权可能都看到 reserved_amount=0.00，
      然后分别判断额度足够，最终把 available credit 算错。
    -->
    <select id="findByIdForUpdate" resultMap="creditAccountRowMap">
        SELECT id, credit_limit, reserved_amount, posted_balance, currency, status
        FROM credit_accounts
        WHERE id = #{accountId}
        FOR UPDATE
    </select>

    <update id="update">
        <!--
          更新样例：credit_limit=10000.00，reserved_amount=3000.00，posted_balance=4800.00，
          则 available_credit 由 domain 计算为 2200.00，不单独落库。
          只持久化 source fields 可以避免 derived value 和源字段漂移；
          DB CHECK 会兜底保证 reserved_amount + posted_balance 不超过 credit_limit。
        -->
        UPDATE credit_accounts
        SET reserved_amount = #{reservedAmount},
            posted_balance = #{postedBalance},
            status = #{status}
        WHERE id = #{id}
    </update>

</mapper>
