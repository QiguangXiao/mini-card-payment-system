<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minicard.messaging.inbox.mybatis.ConsumerInboxMapper">

    <insert id="insert">
        <!--
          这里不用 SELECT 再 INSERT，而是直接 INSERT 让 unique key 判定第一次消费。
          MyBatis 返回 affected rows；DuplicateKeyException 在 repository adapter 中转成 false。
        -->
        INSERT INTO consumer_inbox (consumer_name, event_id, processed_at)
        VALUES (#{consumerName}, #{eventId}, #{processedAt})
    </insert>

</mapper>
