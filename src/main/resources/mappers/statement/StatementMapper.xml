<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minicard.statement.infrastructure.mybatis.StatementMapper">

    <resultMap id="statementRowMap"
               type="com.minicard.statement.infrastructure.mybatis.StatementRow">
        <constructor>
            <arg column="id" javaType="java.lang.String"/>
            <arg column="credit_account_id" javaType="java.lang.String"/>
            <arg column="period_start" javaType="java.time.LocalDate"/>
            <arg column="period_end" javaType="java.time.LocalDate"/>
            <arg column="due_date" javaType="java.time.LocalDate"/>
            <arg column="total_amount" javaType="java.math.BigDecimal"/>
            <arg column="minimum_payment_amount" javaType="java.math.BigDecimal"/>
            <arg column="paid_amount" javaType="java.math.BigDecimal"/>
            <arg column="currency" javaType="java.lang.String"/>
            <!-- MyBatis 的 _int 表示 primitive int；这里 transaction_count 不允许为 null。 -->
            <arg column="transaction_count" javaType="_int"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="version" javaType="_long"/>
            <arg column="generated_at" javaType="java.time.Instant"/>
            <arg column="created_at" javaType="java.time.Instant"/>
            <arg column="updated_at" javaType="java.time.Instant"/>
        </constructor>
    </resultMap>

    <resultMap id="statementItemRowMap"
               type="com.minicard.statement.infrastructure.mybatis.StatementLineRow">
        <constructor>
            <arg column="id" javaType="java.lang.String"/>
            <arg column="statement_id" javaType="java.lang.String"/>
            <arg column="card_transaction_id" javaType="java.lang.String"/>
            <arg column="ledger_entry_id" javaType="java.lang.String"/>
            <arg column="network_transaction_id" javaType="java.lang.String"/>
            <arg column="authorization_id" javaType="java.lang.String"/>
            <arg column="card_id" javaType="java.lang.String"/>
            <arg column="amount" javaType="java.math.BigDecimal"/>
            <arg column="currency" javaType="java.lang.String"/>
            <arg column="posted_at" javaType="java.time.Instant"/>
            <arg column="created_at" javaType="java.time.Instant"/>
        </constructor>
    </resultMap>

    <sql id="statementColumns">
        id, credit_account_id, period_start, period_end, due_date,
        total_amount, minimum_payment_amount, paid_amount, currency,
        transaction_count, status, version, generated_at, created_at, updated_at
    </sql>

    <sql id="statementItemColumns">
        id, statement_id, card_transaction_id, ledger_entry_id, network_transaction_id,
        authorization_id, card_id, amount, currency, posted_at, created_at
    </sql>

    <insert id="insertStatement">
        <!--
          插入样例：id='77777777-7777-7777-7777-777777777701'，
          credit_account_id='11111111-1111-1111-1111-111111111111'，
          period_start='2026-06-01'，period_end='2026-06-30'，due_date='2026-07-25'，
          total_amount=1200.00，minimum_payment_amount=120.00，status='OPEN'。
          防重复样例：uk_statements_cycle(credit_account_id, period_start, period_end)
          阻止同一账户同一账期生成两张 statement。
        -->
        INSERT INTO statements (
            <include refid="statementColumns"/>
        ) VALUES (
            #{id},
            #{creditAccountId},
            #{periodStart},
            #{periodEnd},
            #{dueDate},
            #{totalAmount},
            #{minimumPaymentAmount},
            #{paidAmount},
            #{currency},
            #{transactionCount},
            #{status},
            #{version},
            #{generatedAt},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

    <insert id="insertItem">
        <!--
          插入样例：id='77777777-7777-7777-7777-7777777777a1'，
          statement_id='77777777-7777-7777-7777-777777777701'，
          card_transaction_id='aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa1'，
          ledger_entry_id='bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbb1'。
          防重复样例：statement_lines.card_transaction_id 和 ledger_entry_id 的 unique key
          分别防止同一交易或同一 ledger fact 被重复放进账单。
        -->
        INSERT INTO statement_lines (
            <include refid="statementItemColumns"/>
        ) VALUES (
            #{id},
            #{statementId},
            #{cardTransactionId},
            #{ledgerEntryId,jdbcType=CHAR},
            #{networkTransactionId},
            #{authorizationId},
            #{cardId},
            #{amount},
            #{currency},
            #{postedAt},
            #{createdAt}
        )
    </insert>

    <select id="findByCycleForUpdate" resultMap="statementRowMap">
        <!--
          查询样例：creditAccountId='11111111-1111-1111-1111-111111111111'，
          periodStart='2026-06-01'，periodEnd='2026-06-30'。
          对应索引：uk_statements_cycle(credit_account_id, period_start, period_end)。
          FOR UPDATE 让并发生成或补偿路径等待同一周期 statement 的最终状态，避免重复插入。
        -->
        SELECT <include refid="statementColumns"/>
        FROM statements
        WHERE credit_account_id = #{creditAccountId}
          AND period_start = #{periodStart}
          AND period_end = #{periodEnd}
        FOR UPDATE
    </select>

    <select id="findById" resultMap="statementRowMap">
        <!--
          查询样例：id='77777777-7777-7777-7777-777777777701'。
          访问路径：走 statements.PRIMARY KEY(id)，用于 API 读取，不锁 row。
        -->
        SELECT <include refid="statementColumns"/>
        FROM statements
        WHERE id = #{id}
    </select>

    <select id="findByIdForUpdate" resultMap="statementRowMap">
        <!--
          查询样例：id='77777777-7777-7777-7777-777777777701'。
          还款、逾期扫描、账单修正这类会改 paid_amount/status 的路径必须 locking read。
          如果还款并发不用这把 row lock，两次支付可能都基于旧 paid_amount 计算，导致状态错误。
        -->
        SELECT <include refid="statementColumns"/>
        FROM statements
        WHERE id = #{id}
        FOR UPDATE
    </select>

    <update id="updatePayment">
        <!--
          更新样例：paid_amount=500.00，status='OPEN' 或 'PAID'，version=3。
          version 随付款状态变化递增，给 cache/read model 做 freshness 判断；
          如果只改 paid_amount 不改 version，缓存层可能继续相信旧账单快照。
        -->
        UPDATE statements
        SET paid_amount = #{paidAmount},
            status = #{status},
            version = #{version},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <select id="findItemsByStatementId" resultMap="statementItemRowMap">
        <!--
          查询样例：statementId='77777777-7777-7777-7777-777777777701'。
          访问路径：idx_statement_lines_statement(statement_id, posted_at, card_transaction_id)
          支持按账单取明细并稳定排序，避免 API 每次返回顺序跳动。
        -->
        SELECT <include refid="statementItemColumns"/>
        FROM statement_lines
        WHERE statement_id = #{statementId}
        ORDER BY posted_at, card_transaction_id
    </select>

</mapper>
