<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minicard.statement.infrastructure.mybatis.StatementBatchMapper">

    <resultMap id="statementBatchRowMap"
               type="com.minicard.statement.infrastructure.mybatis.StatementBatchRow">
        <constructor>
            <arg column="id" javaType="java.lang.String"/>
            <arg column="period_start" javaType="java.time.LocalDate"/>
            <arg column="period_end" javaType="java.time.LocalDate"/>
            <arg column="due_date" javaType="java.time.LocalDate"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="total_account_count" javaType="long"/>
            <arg column="target_accounts_per_job" javaType="int"/>
            <arg column="job_count" javaType="int"/>
            <arg column="created_at" javaType="java.time.Instant"/>
            <arg column="completed_at" javaType="java.time.Instant"/>
            <arg column="last_error" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <sql id="statementBatchColumns">
        id, period_start, period_end, due_date, status, total_account_count,
        target_accounts_per_job, job_count, created_at, completed_at, last_error
    </sql>

    <insert id="insert">
        INSERT INTO statement_batches (
            <include refid="statementBatchColumns"/>
        ) VALUES (
            #{id},
            #{periodStart},
            #{periodEnd},
            #{dueDate},
            #{status},
            #{totalAccountCount},
            #{targetAccountsPerJob},
            #{jobCount},
            #{createdAt},
            #{completedAt,jdbcType=TIMESTAMP},
            #{lastError,jdbcType=VARCHAR}
        )
    </insert>

    <select id="findById" resultMap="statementBatchRowMap">
        SELECT <include refid="statementBatchColumns"/>
        FROM statement_batches
        WHERE id = #{id}
    </select>

    <select id="findByIdForUpdate" resultMap="statementBatchRowMap">
        SELECT <include refid="statementBatchColumns"/>
        FROM statement_batches
        WHERE id = #{id}
        FOR UPDATE
    </select>

    <update id="updateState">
        UPDATE statement_batches
        SET status = #{status},
            completed_at = #{completedAt,jdbcType=TIMESTAMP},
            last_error = #{lastError,jdbcType=VARCHAR}
        WHERE id = #{id}
    </update>

</mapper>
