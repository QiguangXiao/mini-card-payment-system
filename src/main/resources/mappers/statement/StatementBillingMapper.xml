<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minicard.statement.infrastructure.mybatis.StatementBillingMapper">

    <resultMap id="statementLineSourceRowMap"
               type="com.minicard.statement.infrastructure.mybatis.StatementLineSourceRow">
        <constructor>
            <arg column="card_transaction_id" javaType="java.lang.String"/>
            <arg column="network_transaction_id" javaType="java.lang.String"/>
            <arg column="authorization_id" javaType="java.lang.String"/>
            <arg column="card_id" javaType="java.lang.String"/>
            <arg column="amount" javaType="java.math.BigDecimal"/>
            <arg column="currency" javaType="java.lang.String"/>
            <arg column="posted_at" javaType="java.time.Instant"/>
        </constructor>
    </resultMap>

    <select id="countBillableAccounts" resultType="long">
        <!--
          统计样例：periodStartInclusive='2026-06-01T00:00:00Z'，
          periodEndExclusive='2026-07-01T00:00:00Z'。
          访问路径：idx_card_transactions_billing_batch(status, billing_status, posted_at, credit_account_id)
          先定位本账期 UNBILLED/POSTED 交易，再 COUNT(DISTINCT credit_account_id) 估算 job 数量。
          这里不加锁，因为它只是生成 StatementJob 的参考计数；真正防重复在 job 唯一键和单账户出账锁里完成。
        -->
        SELECT COUNT(DISTINCT credit_account_id)
        FROM card_transactions
        WHERE status = 'POSTED'
          AND billing_status = 'UNBILLED'
          AND posted_at &gt;= #{periodStartInclusive}
          AND posted_at &lt; #{periodEndExclusive}
    </select>

    <!--
      StatementJob 的账户分片查询。

      核心表达式：
        MOD(CRC32(credit_account_id), shardCount) = shardNo

      CRC32 是 MySQL 内置的 deterministic checksum 函数：
      - 输入同一个字符串 credit_account_id，每次都会得到同一个 32-bit 整数；
      - 它不是加密 hash，只是足够便宜、稳定、分布大致均匀的分片 hash；
      - 再对 shardCount 取模，就把账户稳定映射到 0..shardCount-1 的某个 shard。

      具体例子（数字是假设值，帮助理解）：
        CRC32('account-A') = 101
        CRC32('account-B') = 102
        shardCount = 3
        account-A -> MOD(101, 3) = 2，所以只会被 shardNo=2 的 job 处理
        account-B -> MOD(102, 3) = 0，所以只会被 shardNo=0 的 job 处理

      为什么按 account 分片，而不是按 card_transaction 分片：
      - StatementGenerationService.generate(accountId, period) 会一次性锁住这个账户本账期所有候选交易；
      - 同一账户的多笔消费必须进入同一张 statement；
      - 如果按交易分片，同一个 account 的两笔交易可能落到两个 job，两个 job 会同时尝试生成同一账户同一期账单。

      DISTINCT credit_account_id 的含义：
      - 这里先找“本 shard 要处理哪些账户”，不是直接找所有交易；
      - handler 后续逐账户调用 StatementGenerationService；
      - 真正取该账户全部消费、FOR UPDATE 锁交易、生成 statement_lines 的查询在 findBillableLineSourcesForUpdate。

      这里不加 FOR UPDATE：
      - 本查询只是 dispatcher/handler 的 fan-out 列表；
      - 真正并发控制在单账户生成时锁 credit account + candidate card_transactions rows；
      - 即使两个 job 因重试等原因重复看到同一账户，statement cycle unique key 和 BILLED 标记仍会兜底。

      索引注意：
      - CRC32(credit_account_id) 是函数计算，MySQL 不能直接用普通 BTree 索引做范围定位；
      - 所以前面的 status/billing_status/posted_at 条件先靠 idx_card_transactions_billing_batch 缩小候选集合；
      - 然后再对候选 account 做 CRC32 + MOD 分片。
    -->
    <select id="findAccountIdsForJob" resultType="java.lang.String">
        SELECT DISTINCT credit_account_id
        FROM card_transactions
        WHERE status = 'POSTED'
          AND billing_status = 'UNBILLED'
          AND posted_at &gt;= #{periodStartInclusive}
          AND posted_at &lt; #{periodEndExclusive}
          AND MOD(CRC32(credit_account_id), #{shardCount}) = #{shardNo}
        ORDER BY credit_account_id
    </select>

    <!--
      生成 statement line 前同时锁住 card_transactions row。
      statement_lines.card_transaction_id unique key 是数据库侧第二道防重复出账保护。
      查询样例：同一账户 2026-06 账期内，锁住所有 status='POSTED' 且 billing_status='UNBILLED' 的候选交易。
      索引样例：idx_card_transactions_statement_candidates
      (credit_account_id, status, billing_status, statement_id, posted_at) 能把候选范围压到单账户单账期。
      如果没有 FOR UPDATE，两个 statement worker 可能同时读取同一批候选交易，再各自插入 statement_lines。
    -->
    <select id="findBillableLineSourcesForUpdate" resultMap="statementLineSourceRowMap">
        SELECT
            c.id AS card_transaction_id,
            c.network_transaction_id,
            c.authorization_id,
            c.card_id,
            c.amount,
            c.currency,
            c.posted_at
        FROM card_transactions c
        WHERE c.credit_account_id = #{creditAccountId}
          AND c.status = 'POSTED'
          AND c.billing_status = 'UNBILLED'
          AND c.statement_id IS NULL
          AND c.posted_at &gt;= #{periodStartInclusive}
          AND c.posted_at &lt; #{periodEndExclusive}
        ORDER BY c.posted_at, c.id
        FOR UPDATE
    </select>

    <update id="markCardTransactionsBilled">
        <!--
          更新样例：statementId='77777777-7777-7777-7777-777777777701'，
          cardTransactionIds=('aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa1','aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa2')。
          防重复条件：只有仍然 POSTED/UNBILLED 且 statement_id IS NULL 的交易会被标记。
          如果某笔交易已经被别的账单任务抢先标记，本 UPDATE 不会覆盖它；service 应关注 affected rows 是否符合预期。
        -->
        UPDATE card_transactions
        SET billing_status = 'BILLED',
            statement_id = #{statementId},
            statement_assigned_at = #{billedAt},
            updated_at = #{billedAt}
        WHERE status = 'POSTED'
          AND billing_status = 'UNBILLED'
          AND statement_id IS NULL
          AND id IN
          <foreach collection="cardTransactionIds" item="cardTransactionId" open="(" separator="," close=")">
              #{cardTransactionId}
          </foreach>
    </update>

</mapper>
