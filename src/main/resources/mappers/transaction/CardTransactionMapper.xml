<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minicard.transaction.infrastructure.mybatis.CardTransactionMapper">

    <resultMap id="cardTransactionRowMap"
               type="com.minicard.transaction.infrastructure.mybatis.CardTransactionRow">
        <constructor>
            <arg column="id" javaType="java.lang.String"/>
            <arg column="network_transaction_id" javaType="java.lang.String"/>
            <arg column="authorization_id" javaType="java.lang.String"/>
            <arg column="card_id" javaType="java.lang.String"/>
            <arg column="credit_account_id" javaType="java.lang.String"/>
            <arg column="amount" javaType="java.math.BigDecimal"/>
            <arg column="currency" javaType="java.lang.String"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="presentment_received_at" javaType="java.time.Instant"/>
            <arg column="posted_at" javaType="java.time.Instant"/>
            <arg column="statement_id" javaType="java.lang.String"/>
            <arg column="statement_assigned_at" javaType="java.time.Instant"/>
            <arg column="created_at" javaType="java.time.Instant"/>
            <arg column="updated_at" javaType="java.time.Instant"/>
        </constructor>
    </resultMap>

    <sql id="cardTransactionColumns">
        id, network_transaction_id, authorization_id, card_id, credit_account_id,
        amount, currency, status, presentment_received_at, posted_at,
        statement_id, statement_assigned_at, created_at, updated_at
    </sql>

    <insert id="insert">
        INSERT INTO card_transactions (
            <include refid="cardTransactionColumns"/>
        ) VALUES (
            #{id},
            #{networkTransactionId},
            #{authorizationId},
            #{cardId},
            #{creditAccountId},
            #{amount},
            #{currency},
            #{status},
            #{presentmentReceivedAt},
            #{postedAt,jdbcType=TIMESTAMP},
            #{statementId,jdbcType=CHAR},
            #{statementAssignedAt,jdbcType=TIMESTAMP},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

    <!--
      network_transaction_id 是 presentment 的 idempotency key。
      duplicate retry 会等待原 transaction 完成，然后读取最终 POSTED 结果。
    -->
    <select id="findByNetworkTransactionIdForUpdate" resultMap="cardTransactionRowMap">
        SELECT <include refid="cardTransactionColumns"/>
        FROM card_transactions
        WHERE network_transaction_id = #{networkTransactionId}
        FOR UPDATE
    </select>

    <!--
      Statement generation 只收录 POSTED 且 statement_id 为空的交易。
      FOR UPDATE 防止两次并发账单生成把同一笔交易重复归入不同 statement。
    -->
    <select id="findUnbilledPostedByCreditAccountForUpdate" resultMap="cardTransactionRowMap">
        SELECT <include refid="cardTransactionColumns"/>
        FROM card_transactions
        WHERE credit_account_id = #{creditAccountId}
          AND status = 'POSTED'
          AND statement_id IS NULL
          AND posted_at >= #{postedAtFromInclusive}
          AND posted_at &lt; #{postedAtToExclusive}
        ORDER BY posted_at, id
        FOR UPDATE
    </select>

    <update id="assignStatement">
        <!--
          <foreach> 在一条 SQL 中生成多组 CASE WHEN 和 IN 参数。
          如果逐条 UPDATE，每笔交易都要一次 round trip；如果手写字符串拼接，又会回到 SQL injection 风险。
        -->
        UPDATE card_transactions
        SET statement_id = CASE id
            <foreach collection="transactions" item="transaction">
                WHEN #{transaction.id} THEN #{transaction.statementId}
            </foreach>
            END,
            statement_assigned_at = CASE id
            <foreach collection="transactions" item="transaction">
                WHEN #{transaction.id} THEN #{transaction.statementAssignedAt}
            </foreach>
            END,
            updated_at = CASE id
            <foreach collection="transactions" item="transaction">
                WHEN #{transaction.id} THEN #{transaction.updatedAt}
            </foreach>
            END
        WHERE status = 'POSTED'
          AND statement_id IS NULL
          AND id IN
          <foreach collection="transactions" item="transaction" open="(" separator="," close=")">
              #{transaction.id}
          </foreach>
    </update>

    <update id="update">
        UPDATE card_transactions
        SET status = #{status},
            posted_at = #{postedAt,jdbcType=TIMESTAMP},
            statement_id = #{statementId,jdbcType=CHAR},
            statement_assigned_at = #{statementAssignedAt,jdbcType=TIMESTAMP},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

</mapper>
